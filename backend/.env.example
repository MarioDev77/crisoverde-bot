# Crisoverde Bot (Groq) — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Chave da API do Groq (gratuito, funciona no Brasil)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_aqui

# Porta do servidor (padrão: 3001)
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# Origens permitidas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Limite de requisições por IP por minuto
RATE_LIMIT_MAX=30

# Token fixo para as rotas administrativas legadas (/memory, /security/*)
ADMIN_TOKEN=gere_com_openssl_rand_hex_32

# Segredo usado para assinar os JWTs de sessão (login/cadastro).
# Gere com: openssl rand -hex 32
JWT_SECRET=gere_com_openssl_rand_hex_32

# String de conexão do PostgreSQL (Railway)
DATABASE_URL=postgresql://usuario:senha@host:porta/banco
